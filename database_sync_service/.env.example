# Supabase Credentials
# WARNING: Use the 'service_role' secret key (not the anon key) to bypass Row Level Security and delete archived tasks.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Local SQL Server (SSMS) Config
# Set SQL_AUTH_TYPE to 'ntlm' for Windows Authentication, or 'default' for SQL Server Authentication.
SQL_SERVER_NAME=localhost
SQL_DATABASE_NAME=ReportingSystemArchive
SQL_AUTH_TYPE=ntlm
SQL_USER=your-windows-username
SQL_PASSWORD=your-windows-password
SQL_DOMAIN=WORKGROUP

# Optional: Port and Instance Name (Common for SQLEXPRESS dynamic ports)
# If SQL Server is configured on a non-default port or uses a named instance (like SQLEXPRESS).
# SQL_PORT=1433
# SQL_INSTANCE_NAME=SQLEXPRESS


# Sync & Archiving Settings
# Number of days of task reports to keep live on the Supabase cloud.
SYNC_RETENTION_DAYS=30

# Interval in hours for the service to check and run the synchronization task.
SYNC_INTERVAL_HOURS=24

# SMTP Configuration (For direct email sending of consolidated reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sanjeev520212@gmail.com
SMTP_PASSWORD=cqyo jqui drpj oomf
